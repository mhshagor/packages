{
  "name": "mhshagor/laravel-components",
  "description": "Laravel Components - Beautiful components for Laravel",
  "keywords": [
    "laravel",
    "components"
  ],
  "version": "1.0.9",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.0",
    "mhshagor/file-picker": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Mhshagor\\LaravelComponents\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mhshagor\\LaravelComponents\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/pest"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Mhshagor\\LaravelComponents\\Providers\\PackageServiceProvider"
      ]
    }
  },
  "authors": [
    {
      "name": "M.H SHAGOR",
      "email": "srq001100@gmail.com"
    }
  ],
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
